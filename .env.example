# Web
NEXT_PUBLIC_API_URL=http://localhost:4020
# Optional pre-issued actor token for browser API + realtime auth in authenticated modes.
NEXT_PUBLIC_BOPO_ACTOR_TOKEN=

# API
PORT=4020
BOPO_DB_PATH=

# Deployment mode:
# - local
# - authenticated_private
# - authenticated_public
BOPO_DEPLOYMENT_MODE=local

# Required in authenticated modes.
BOPO_ALLOWED_ORIGINS=http://localhost:4010
BOPO_ALLOWED_HOSTNAMES=localhost,127.0.0.1
BOPO_PUBLIC_BASE_URL=

# Auth identity configuration.
# Provide at least one in authenticated modes:
# - BOPO_AUTH_TOKEN_SECRET for Bearer/query actor tokens
# - BOPO_TRUST_ACTOR_HEADERS=1 when a trusted reverse proxy injects x-actor-* headers
BOPO_AUTH_TOKEN_SECRET=
BOPO_TRUST_ACTOR_HEADERS=0

# Optional bootstrap secret for POST /auth/actor-token in authenticated modes.
BOPO_AUTH_BOOTSTRAP_SECRET=

# Scheduler ownership:
# - auto (default single-instance behavior)
# - leader (this instance runs scheduler sweeps)
# - follower (this instance does not run scheduler sweeps)
# - off (disable scheduler sweeps)
BOPO_SCHEDULER_ROLE=auto

# Git workspace execution controls
# Enable isolated git worktree runtime mode for projects using
# executionWorkspacePolicy.mode=isolated + strategy.type=git_worktree.
BOPO_ENABLE_GIT_WORKTREE_ISOLATION=0
# Cleanup TTL for stale isolated worktrees.
BOPO_GIT_WORKTREE_TTL_MINUTES=240
